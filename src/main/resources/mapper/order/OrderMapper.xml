<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sweetscoop.order.mapper.OrderMapper">

    <!-- 주문 저장 -->
    <insert id="insertOrder"
		    parameterType="com.sweetscoop.order.model.OrderVO"    
            useGeneratedKeys="true"
            keyProperty="id">

        INSERT INTO ORDERS
        (
            customer_id,
            branch_id,
            kiosk_id,
            order_type,
            language,
            status,
            created_at,
            waiting_no,
            receipt_no,
            total_price,
            coupon_used
        )
        VALUES
        (
            #{customerId},
            #{branchId},
            #{kioskId},
            #{orderType},
            #{language},
            #{status},
            #{createdAt},
            #{waitingNo},
            #{receiptNo},
            #{totalPrice},
            #{couponUsed}
        )

    </insert>

    <!-- 주문 상품 저장 -->
    <insert id="insertOrderItem"
            parameterType="com.sweetscoop.order.model.OrderItemVO"
            useGeneratedKeys="true"
            keyProperty="id">

        INSERT INTO ORDERITEM
        (
            order_id,
            cup_id,
            size_id,
            quantity,
            total_price
        )
        VALUES
        (
            #{orderId},
            #{cupId},
            #{sizeId},
            #{quantity},
            #{totalPrice}
        )

    </insert>

    <!-- 주문 맛 저장 -->
    <insert id="insertOrderItemMenu"
            parameterType="com.sweetscoop.order.model.OrderItemMenuVO"
            useGeneratedKeys="true"
            keyProperty="id">

        INSERT INTO ORDERITEMMENU
        (
            order_item_id,
            menu_id
        )
        VALUES
        (
            #{orderItemId},
            #{menuId}
        )

    </insert>

    <!-- 주문 옵션 저장 -->
    <insert id="insertOrderItemOption"
            parameterType="com.sweetscoop.order.model.OrderItemOptionVO"
            useGeneratedKeys="true"
            keyProperty="id">

        INSERT INTO ORDERITEMOPTION
        (
            order_item_id,
            menu_option_id
        )
        VALUES
        (
            #{orderItemId},
            #{menuOptionId}
        )

    </insert>

    <!-- 주문 1건 조회 -->
    <select id="selectOrder"
            parameterType="int"
            resultType="com.sweetscoop.order.model.OrderVO">

        SELECT *
        FROM ORDERS
        WHERE id = #{id}

    </select>

    <!-- 주문 목록 조회 -->
    <select id="selectOrderList"
            resultType="com.sweetscoop.order.model.OrderVO">

        SELECT *
        FROM ORDERS
        ORDER BY created_at DESC

    </select>

    <!-- 주문 상태 변경 -->
    <update id="updateOrderStatus"
            parameterType="com.sweetscoop.order.model.OrderVO">

        UPDATE ORDERS
        SET status = #{status}
        WHERE id = #{id}

    </update>

    <!-- 주문 삭제 -->
    <delete id="deleteOrder"
            parameterType="int">

        DELETE
        FROM ORDERS
        WHERE id = #{id}

    </delete>

</mapper>