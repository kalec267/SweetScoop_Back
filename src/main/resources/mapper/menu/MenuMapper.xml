<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"https://mybatis.org/dtd/mybatis-3-mapper.dtd">


<mapper namespace="com.sweetscoop.menu.repository.MenuDAO">

	<!-- 전체 메뉴 조회 -->
	<select id="findAll"
		resultType="com.sweetscoop.menu.dto.MenuDTO">

		SELECT
		id,
		category_id,
		name,
		price,
		menu_img
		
		FROM MENU

	</select>


	<!-- 메뉴 상세 조회 -->
	<select id="findById" parameterType="int"
		resultType="com.sweetscoop.menu.dto.MenuDTO">

		SELECT
		id,
		category_id,
		item_id,
		name,
		price,
		menu_img
		FROM MENU
		WHERE id = #{id}

	</select>


	<!-- 카테고리별 메뉴 조회 -->
	<select id="findByCategory" parameterType="int"
		resultType="com.sweetscoop.menu.dto.MenuDTO">

		SELECT
		id,
		category_id,
		item_id,
		name,
		menu_img
		FROM MENU
		WHERE category_id = #{categoryId}

	</select>


</mapper>