<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sweetscoop.option.repository.MenuOptionDAO">

    <select id="findByCategoryId"
            resultType="com.sweetscoop.option.dto.MenuOptionDTO">

        SELECT
            id,
            category_id,
            name,
            price,
            is_active
        FROM MENU_OPTION
        WHERE category_id = #{categoryId}
          AND is_active = TRUE
        ORDER BY id

    </select>

</mapper>